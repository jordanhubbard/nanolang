#!/usr/bin/env bash
# nanoc-pkg — thin wrapper that delegates to scripts/nano-pkg.sh
# Usage: nanoc-pkg install | publish | update | init | list | info

set -euo pipefail

# Resolve project root (this script lives in bin/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

exec "$PROJECT_ROOT/scripts/nano-pkg.sh" "$@"
