<mujoco model="nano_cartpole">
  <compiler angle="degree" coordinate="local"/>
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <geom friction="0.8 0.1 0.1" density="500" rgba="0.7 0.7 0.7 1"/>
    <joint damping="0.03"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" pos="0 0 -0.05" size="8 2 0.1" rgba="0.08 0.09 0.10 1"/>

    <body name="cart" pos="0 0 0.20">
      <joint name="slide" type="slide" axis="1 0 0" limited="true" range="-2.8 2.8" damping="0.12"/>
      <geom name="cart_geom" type="box" size="0.28 0.18 0.12" mass="1.0" rgba="0.12 0.44 0.82 1"/>

      <body name="pole" pos="0 0 0.12">
        <joint name="hinge" type="hinge" axis="0 1 0" damping="0.02"/>
        <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 1.15" size="0.035" mass="0.18" rgba="0.95 0.72 0.24 1"/>
        <body name="tip" pos="0 0 1.15">
          <geom name="tip_geom" type="sphere" size="0.08" mass="0.03" rgba="0.95 0.22 0.18 1"/>
          <site name="tip_site" pos="0 0 0" size="0.025" rgba="1 1 1 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="cart_motor" joint="slide" gear="80" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
