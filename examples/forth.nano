# Example: FIG-Forth Interpreter
# Purpose: A complete FIG-Forth compatible interpreter in nanolang showcasing language capabilities
# Features: structs, arrays, HashMap, token threading, REPL, colon definitions, control structures
# Difficulty: Expert
# Category: language
# Prerequisites: nl_struct, nl_hashmap, nl_array_complete, simple_repl
# Expected Output: FIG-Forth demo output

from "modules/std/collections/stringbuilder.nano" import StringBuilder, sb_new, sb_append, sb_to_string

# ── Bitwise helpers (nanolang lacks native bitwise operators) ─────────────────

fn floored_div2(n: int) -> int {
    # Floored division by 2: truncated, but adjusted for negatives
    let q: int = (/ n 2)
    let r: int = (% n 2)
    if (and (< r 0) (> 2 0)) { return (- q 1) }
    return q
}

shadow floored_div2 {
    assert (== (floored_div2 8) 4)
    assert (== (floored_div2 7) 3)
    assert (== (floored_div2 -1) -1)
}

fn floored_mod2(n: int) -> int {
    # Floored modulo by 2: result is always 0 or 1
    let r: int = (% n 2)
    if (< r 0) { return (+ r 2) }
    return r
}

shadow floored_mod2 {
    assert (== (floored_mod2 0) 0)
    assert (== (floored_mod2 1) 1)
    assert (== (floored_mod2 4) 0)
    assert (== (floored_mod2 -1) 1)
}

fn bit_and(a: int, b: int) -> int {
    let mut result: int = 0
    let mut power: int = 1
    let mut av: int = a
    let mut bv: int = b
    let mut i: int = 0
    while (< i 63) {
        if (and (== (floored_mod2 av) 1) (== (floored_mod2 bv) 1)) {
            set result (+ result power)
        } else { (print "") }
        set av (floored_div2 av)
        set bv (floored_div2 bv)
        if (< i 62) { set power (* power 2) } else { (print "") }
        set i (+ i 1)
    }
    if (and (< av 0) (< bv 0)) {
        set result (+ result (- (- 0 9223372036854775807) 1))
    } else { (print "") }
    return result
}

shadow bit_and {
    assert (== (bit_and 5 3) 1)
    assert (== (bit_and 12 10) 8)
    assert (== (bit_and 0 255) 0)
    assert (== (bit_and -1 -1) -1)
}

fn bit_or(a: int, b: int) -> int {
    let mut result: int = 0
    let mut power: int = 1
    let mut av: int = a
    let mut bv: int = b
    let mut i: int = 0
    while (< i 63) {
        if (or (== (floored_mod2 av) 1) (== (floored_mod2 bv) 1)) {
            set result (+ result power)
        } else { (print "") }
        set av (floored_div2 av)
        set bv (floored_div2 bv)
        if (< i 62) { set power (* power 2) } else { (print "") }
        set i (+ i 1)
    }
    if (or (< av 0) (< bv 0)) {
        set result (+ result (- (- 0 9223372036854775807) 1))
    } else { (print "") }
    return result
}

shadow bit_or {
    assert (== (bit_or 5 3) 7)
    assert (== (bit_or 12 10) 14)
    assert (== (bit_or 0 0) 0)
}

fn bit_xor(a: int, b: int) -> int {
    let mut result: int = 0
    let mut power: int = 1
    let mut av: int = a
    let mut bv: int = b
    let mut i: int = 0
    while (< i 63) {
        if (!= (floored_mod2 av) (floored_mod2 bv)) {
            set result (+ result power)
        } else { (print "") }
        set av (floored_div2 av)
        set bv (floored_div2 bv)
        if (< i 62) { set power (* power 2) } else { (print "") }
        set i (+ i 1)
    }
    let a_neg: bool = (< av 0)
    let b_neg: bool = (< bv 0)
    if (and (or a_neg b_neg) (not (and a_neg b_neg))) {
        set result (+ result (- (- 0 9223372036854775807) 1))
    } else { (print "") }
    return result
}

shadow bit_xor {
    assert (== (bit_xor 5 3) 6)
    assert (== (bit_xor 12 10) 6)
    assert (== (bit_xor 0 0) 0)
}

fn bit_not(a: int) -> int {
    return (- (- 0 a) 1)
}

shadow bit_not {
    assert (== (bit_not 0) -1)
    assert (== (bit_not -1) 0)
    assert (== (bit_not 5) -6)
}

fn power2(n: int) -> int {
    let mut result: int = 1
    let mut i: int = 0
    while (< i n) {
        set result (* result 2)
        set i (+ i 1)
    }
    return result
}

shadow power2 {
    assert (== (power2 0) 1)
    assert (== (power2 1) 2)
    assert (== (power2 8) 256)
}

fn bit_lshift(a: int, n: int) -> int {
    return (* a (power2 n))
}

shadow bit_lshift {
    assert (== (bit_lshift 1 3) 8)
    assert (== (bit_lshift 5 2) 20)
}

fn bit_rshift(a: int, n: int) -> int {
    return (/ a (power2 n))
}

shadow bit_rshift {
    assert (== (bit_rshift 8 3) 1)
    assert (== (bit_rshift 20 2) 5)
}

