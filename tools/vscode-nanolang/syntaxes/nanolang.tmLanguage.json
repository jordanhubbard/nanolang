{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "NanoLang",
    "scopeName": "source.nanolang",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#storage" },
        { "include": "#types" },
        { "include": "#builtin-types" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.nanolang",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.nanolang",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.nanolang",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.nanolang",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.nanolang",
                    "match": "\\b(if|else|while|for|in|match|return|break|continue|cond|do)\\b"
                },
                {
                    "name": "keyword.declaration.nanolang",
                    "match": "\\b(fn|shadow|let|var|const|struct|enum|type|union|module|import|use|pub|extern|inline|static|mutable)\\b"
                },
                {
                    "name": "keyword.operator.logical.nanolang",
                    "match": "\\b(and|or|not)\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.modifier.nanolang",
                    "match": "\\b(pub|extern|inline|static|mutable|volatile|signed|unsigned)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.nanolang",
                    "match": "\\b(int|float|string|bool|void|bstring)\\b"
                }
            ]
        },
        "builtin-types": {
            "patterns": [
                {
                    "name": "support.type.nanolang",
                    "match": "\\b(Int|Float|String|Bool|Void|List|HashMap|Option|Result|Status|Byte|Char)\\b"
                },
                {
                    "comment": "Generic type params e.g. List<Int>",
                    "name": "support.type.nanolang",
                    "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.nanolang",
                    "match": "\\b(true|false|nil|null|none|ok|err)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.nanolang",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.float.nanolang",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.nanolang",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.nanolang",
                    "match": "\\?|->|=>|::|:=|==|!=|<=|>=|<|>|=|\\+|-|\\*|/|%|&|\\||\\^|~|!|\\.\\.\\."
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "comment": "Function definition: fn name or shadow name",
                    "name": "entity.name.function.nanolang",
                    "match": "(?<=\\bfn\\s|\\bshadow\\s)[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "comment": "Function call",
                    "name": "entity.name.function.call.nanolang",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.nanolang",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
