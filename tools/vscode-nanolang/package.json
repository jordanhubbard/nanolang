{
    "name": "nanolang",
    "displayName": "NanoLang",
    "description": "Language support for NanoLang v3.3 — syntax highlighting, snippets, and language configuration",
    "version": "0.2.0",
    "publisher": "nanolang",
    "repository": {
        "type": "git",
        "url": "https://github.com/jordanhubbard/nanolang"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "nanolang",
        "nano",
        "compiled",
        "transpiler",
        "modules",
        "pattern-matching"
    ],
    "contributes": {
        "languages": [
            {
                "id": "nanolang",
                "aliases": [
                    "NanoLang",
                    "nanolang",
                    "nano"
                ],
                "extensions": [
                    ".nano"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/nanolang-icon.png",
                    "dark": "./icons/nanolang-icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "nanolang",
                "scopeName": "source.nanolang",
                "path": "./syntaxes/nanolang.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "nanolang",
                "path": "./snippets/nanolang.json"
            }
        ]
    },
    "icon": "icons/nanolang-icon.png",
    "license": "MIT"
}