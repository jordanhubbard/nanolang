struct Info {
    path: string,
    name: string,
    category: string,
    icon: string,
    extra: string
}

fn make_icon(stem: string) -> string {
    let candidate = (+ "icons/" (+ stem ".png"))
    let mod3 = (% (str_length stem) 3)
    if mod3 == 0 { return candidate }
    return ""
}

shadow make_icon {
    assert (== 0 0)
}

fn make_info(p: string) -> Info {
    return Info {
        path: p,
        name: (+ "name_" p),
        category: (+ "cat_" p),
        icon: (make_icon p),
        extra: (+ "extra_" p)
    }
}

shadow make_info {
    let i: Info = (make_info "abc")
    assert (== i.path "abc")
}

fn collect_all() -> array<Info> {
    let mut items: array<Info> = []
    let mut i = 0
    while i < 50 {
        let label = (+ "item_" (int_to_string i))
        let info: Info = (make_info label)
        set items (array_push items info)
        set i (i + 1)
    }
    return items
}

shadow collect_all {
    assert (== 0 0)
}

fn main() -> int {
    let results: array<Info> = (collect_all)
    let count = (array_length results)
    (println f"Count: {count}")

    let mut failures = 0
    let mut i = 0
    while i < count {
        let item: Info = (at results i)
        let expected_path = (+ "item_" (int_to_string i))
        let expected_name = (+ "name_item_" (int_to_string i))
        let expected_extra = (+ "extra_item_" (int_to_string i))
        if item.path != expected_path {
            (println (+ "FAIL path at " (+ (int_to_string i) (+ ": got " item.path))))
            set failures (failures + 1)
        }
        if item.name != expected_name {
            (println (+ "FAIL name at " (+ (int_to_string i) (+ ": got " item.name))))
            set failures (failures + 1)
        }
        if item.extra != expected_extra {
            (println (+ "FAIL extra at " (+ (int_to_string i) (+ ": got " item.extra))))
            set failures (failures + 1)
        }
        let expected_icon = (make_icon expected_path)
        if item.icon != expected_icon {
            let msg = (+ "FAIL icon at " (+ (int_to_string i) (+ ": expected [" (+ expected_icon (+ "] got [" (+ item.icon "]"))))))
            (println msg)
            set failures (failures + 1)
        }
        set i (i + 1)
    }

    if failures == 0 {
        (println "All checks passed!")
    } else {
        (println f"FAILURES: {failures}")
    }
    return failures
}
