# Regression test: module metadata extraction + embedding must not crash.
#
# Importing a module drives compile_module_to_object(), which calls
# extract_module_metadata() and embed_metadata_in_module_c(). Both were
# previously disabled after a bus error. This test keeps the scalar and
# function-signature cases exercised: a successful compile + run proves the
# metadata paths execute safely, and the introspection counts confirm the
# metadata was actually populated (present, not silently absent or a crash).

import "test_modules/metadata_probe.nano" as Probe

# Introspection metadata generated by the transpiler for the imported module.
extern fn ___module_function_count_metadata_probe() -> int
extern fn ___module_struct_count_metadata_probe() -> int
extern fn ___module_is_unsafe_metadata_probe() -> bool
extern fn ___module_has_ffi_metadata_probe() -> bool

fn main() -> int {
    (println "=== Module Metadata Embedding Test ===")

    # The imported module must be usable (its object compiled with embedded
    # metadata without crashing).
    let sum = (Probe.add 2 3)
    if sum != 5 {
        (println "ERROR: Probe.add(2, 3) != 5")
        return 1
    }

    let scaled = (Probe.scale 21 2)
    if scaled != 42 {
        (println "ERROR: Probe.scale(21, 2) != 42")
        return 1
    }

    # Metadata must be present (populated), not absent.
    let fn_count = (___module_function_count_metadata_probe)
    (print "Exported functions: ")
    (println (int_to_string fn_count))
    if fn_count != 2 {
        (println "ERROR: expected 2 exported functions")
        return 1
    }

    let struct_count = (___module_struct_count_metadata_probe)
    (print "Exported structs: ")
    (println (int_to_string struct_count))
    if struct_count != 1 {
        (println "ERROR: expected 1 exported struct")
        return 1
    }

    # Safety flags must reflect a safe, FFI-free module.
    if (___module_is_unsafe_metadata_probe) {
        (println "ERROR: module should be safe")
        return 1
    }
    if (___module_has_ffi_metadata_probe) {
        (println "ERROR: module should have no FFI")
        return 1
    }

    (println "✓ Module metadata embedded and extracted without crashing")
    return 0
}

shadow main {
    assert (== (main) 0)
}
