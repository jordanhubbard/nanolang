-- Sprint 2 stdlib tests: HOFs and string utilities

-- HOFs
assert(sum([1, 2, 3, 4, 5]) == 15, "sum");
assert(product([1, 2, 3, 4]) == 24, "product");
assert(any([1, 2, 3], fn(x) { x > 2 }) == true, "any true");
assert(any([1, 2, 3], fn(x) { x > 10 }) == false, "any false");
assert(all([2, 4, 6], fn(x) { x > 0 }) == true, "all true");
assert(all([2, -1, 6], fn(x) { x > 0 }) == false, "all false");

let r = range(5);
assert(len(r) == 5, "range len");
assert(r[0] == 0, "range start");
assert(r[4] == 4, "range end");

let r2 = range(2, 6);
assert(len(r2) == 4, "range(2,6) len");
assert(r2[0] == 2, "range(2,6) start");

let t = take([10, 20, 30, 40, 50], 3);
assert(len(t) == 3, "take len");
assert(t[2] == 30, "take val");

let d = drop([10, 20, 30, 40, 50], 2);
assert(len(d) == 3, "drop len");
assert(d[0] == 30, "drop val");

let e = enumerate(["a", "b", "c"]);
assert(e[0][0] == 0, "enumerate idx");
assert(e[2][1] == "c", "enumerate val");

let z = zip([1, 2, 3], ["a", "b", "c"]);
assert(z[0][0] == 1, "zip int");
assert(z[0][1] == "a", "zip str");
assert(len(z) == 3, "zip len");

let fl = flatten([[1, 2], [3, 4], [5]]);
assert(len(fl) == 5, "flatten len");
assert(fl[0] == 1, "flatten first");
assert(fl[4] == 5, "flatten last");

let fm = flat_map([1, 2, 3], fn(x) { [x, x * 2] });
assert(len(fm) == 6, "flat_map len");
assert(fm[0] == 1, "flat_map first");
assert(fm[1] == 2, "flat_map second");

let sorted = sort_by([3, 1, 4, 1, 5, 9, 2], fn(x) { x });
assert(sorted[0] == 1, "sort_by first");
assert(sorted[6] == 9, "sort_by last");

-- String utilities
assert(str_repeat("ab", 3) == "ababab", "str_repeat");
assert(str_repeat("x", 0) == "", "str_repeat zero");
assert(str_index_of("hello world", "world") == 6, "str_index_of found");
assert(str_index_of("hello world", "xyz") == -1, "str_index_of miss");
assert(str_index_of("abcabc", "b", 3) == 4, "str_index_of with offset");
assert(str_reverse("hello") == "olleh", "str_reverse");
assert(str_pad_left("42", 5, "0") == "00042", "str_pad_left");
assert(str_pad_right("hi", 5, ".") == "hi...", "str_pad_right");

let ch = chars("abc");
assert(len(ch) == 3, "chars len");
assert(ch[0] == "a", "chars first");
assert(ch[2] == "c", "chars last");

assert(str_format("Hello %s!", "world") == "Hello world!", "str_format str");
assert(str_format("%d + %d = %d", 1, 2, 3) == "1 + 2 = 3", "str_format int");

println("All stdlib sprint2 tests passed.");
