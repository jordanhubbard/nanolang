/* Test: for x in list { } — List<T> iteration */

fn sum_list(items: List<int>) -> int {
    let mut total: int = 0
    for x in items {
        set total (+ total x)
    }
    return total
}

shadow sum_list {
    let items: List<int> = (list_int_new)
    (list_int_push items 1)
    (list_int_push items 2)
    (list_int_push items 3)
    assert (== (sum_list items) 6)
}

fn count_strings(words: List<string>) -> int {
    let mut count: int = 0
    for w in words {
        set count (+ count 1)
    }
    return count
}

shadow count_strings {
    let words: List<string> = (list_string_new)
    (list_string_push words "hello")
    (list_string_push words "world")
    assert (== (count_strings words) 2)
}

fn main() -> int {
    /* Test for-in with range */
    let mut sum_range: int = 0
    for i in (range 0 5) {
        set sum_range (+ sum_range i)
    }
    assert (== sum_range 10)

    /* Test for-in with List<int> */
    let nums: List<int> = (list_int_new)
    (list_int_push nums 10)
    (list_int_push nums 20)
    (list_int_push nums 30)
    let mut total: int = 0
    for n in nums {
        set total (+ total n)
    }
    assert (== total 60)

    /* Test for-in with List<string> */
    let strs: List<string> = (list_string_new)
    (list_string_push strs "a")
    (list_string_push strs "b")
    (list_string_push strs "c")
    let mut scount: int = 0
    for s in strs {
        set scount (+ scount 1)
    }
    assert (== scount 3)

    (println "for-list tests passed")
    return 0
}

shadow main {
    assert (== (main) 0)
}
