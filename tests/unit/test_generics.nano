/*
 * test_generics.nano — typechecker generic type variable unification tests
 *
 * Tests the per-call type variable binding:
 *   - Type variables bind to the first argument's concrete type
 *   - Subsequent uses of the same type variable in the same call are checked
 *     for consistency
 *   - Generic return types resolve to the bound type
 */

/* ── identity: T → T ──────────────────────────────────────────────────── */
fn identity(x: T) -> T {
    return x
}

shadow identity {
    /* Works with int */
    let r1: int = (identity 42)
    assert (== r1 42)
    /* Works with bool */
    let r2: bool = (identity true)
    assert (== r2 true)
    /* Works with different types in different calls */
    assert (== (identity 100) 100)
}

/* ── pair_first: returns first element of consistent pair ──────────────── */
fn pair_first(a: T, b: T) -> T {
    return a
}

shadow pair_first {
    /* Both int — fine */
    let r: int = (pair_first 10 20)
    assert (== r 10)
    /* Both bool — fine */
    let rb: bool = (pair_first true false)
    assert (== rb true)
}

/* ── wrap_add: T+T → T (int arithmetic through generic) ───────────────── */
fn clamp_zero(x: T) -> T {
    /* Just returns the value — tests generic passthrough */
    return x
}

shadow clamp_zero {
    assert (== (clamp_zero 5) 5)
    assert (== (clamp_zero -3) -3)
    assert (str_equals (clamp_zero "hello") "hello")
}

/* ── Generic with Maybe ────────────────────────────────────────────────── */
union Maybe<V> {
    Some { value: V },
    None {}
}

fn maybe_unwrap_or(opt: Maybe<int>, default_val: int) -> int {
    match opt {
        Some(s) => { return s.value },
        None(n) => { return default_val }
    }
}

shadow maybe_unwrap_or {
    assert (== (maybe_unwrap_or Maybe<int>.Some { value: 5 } 0) 5)
    assert (== (maybe_unwrap_or Maybe<int>.None {} 99) 99)
}

fn safe_divide(a: int, b: int) -> Maybe<int> {
    if (== b 0) { return Maybe<int>.None {} }
    return Maybe<int>.Some { value: (/ a b) }
}

shadow safe_divide {
    let r1: Maybe<int> = (safe_divide 10 2)
    assert (== (maybe_unwrap_or r1 0) 5)

    let r2: Maybe<int> = (safe_divide 7 0)
    assert (== (maybe_unwrap_or r2 -1) -1)
}

/* ── max_of: same type T for both args ────────────────────────────────── */
fn max_of(a: T, b: T) -> T {
    if (> a b) { return a }
    return b
}

shadow max_of {
    assert (== (max_of 3 7) 7)
    assert (== (max_of 10 2) 10)
    assert (== (max_of 0 0) 0)
}

/* ── main ──────────────────────────────────────────────────────────────── */
/* Note: bare type-variable generics (identity, pair_first, clamp_zero, max_of)
 * are tested via shadow tests (interpreter path). The compiled C path tests
 * the concrete generic union (Maybe<int>) via safe_divide + maybe_unwrap_or.
 */
fn main() -> int {
    /* Generic with Maybe — works in compiled path with concrete instantiation */
    let d: Maybe<int> = (safe_divide 20 4)
    assert (== (maybe_unwrap_or d -1) 5)

    let z: Maybe<int> = (safe_divide 6 0)
    assert (== (maybe_unwrap_or z 42) 42)

    (println "generics typechecker tests PASSED")
    return 0
}

shadow main {
    assert (== (main) 0)
}
