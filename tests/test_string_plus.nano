/* Test string concatenation with + operator */

fn concat_two(a: string, b: string) -> string {
    return (+ a b)
}

fn concat_three(a: string, b: string, c: string) -> string {
    return (+ (+ a b) c)
}

fn concat_nested(a: string, b: string, c: string) -> string {
    return (+ a (+ b c))
}

fn main() -> int {
    let s1 = "Hello"
    let s2 = " "
    let s3 = "World"

    let result1 = (+ s1 s2)
    (print "Test 1: ")
    (println result1)

    let result2 = (+ (+ s1 s2) s3)
    (print "Test 2: ")
    (println result2)

    let result3 = (+ "nano" "lang")
    (print "Test 3: ")
    (println result3)

    let greeting = (concat_two "Hello" "!")
    (print "Test 4: ")
    (println greeting)

    let full = (concat_three s1 s2 s3)
    (print "Test 5: ")
    (println full)

    let nested = (concat_nested "A" "B" "C")
    (print "Test 6: ")
    (println nested)

    (println "All string + tests passed!")
    return 0
}

