# Tests for string stdlib builtins: str_starts_with, str_ends_with, str_index_of

fn test_str_starts_with() -> int {
    if (not (str_starts_with "hello world" "hello")) {
        (println "FAIL: str_starts_with basic")
        return 1
    } else {}
    if (str_starts_with "hello" "world") {
        (println "FAIL: str_starts_with false case")
        return 1
    } else {}
    if (not (str_starts_with "hello" "")) {
        (println "FAIL: str_starts_with empty prefix")
        return 1
    } else {}
    if (not (str_starts_with "" "")) {
        (println "FAIL: str_starts_with both empty")
        return 1
    } else {}
    if (str_starts_with "" "x") {
        (println "FAIL: str_starts_with empty string non-empty prefix")
        return 1
    } else {}
    if (str_starts_with "abc" "abcd") {
        (println "FAIL: str_starts_with prefix longer than string")
        return 1
    } else {}
    (println "OK: test_str_starts_with passed")
    return 0
}

shadow test_str_starts_with {
    assert (== (test_str_starts_with) 0)
}

fn test_str_ends_with() -> int {
    if (not (str_ends_with "hello.nano" ".nano")) {
        (println "FAIL: str_ends_with basic")
        return 1
    } else {}
    if (str_ends_with "hello.nano" ".c") {
        (println "FAIL: str_ends_with false case")
        return 1
    } else {}
    if (not (str_ends_with "hello" "")) {
        (println "FAIL: str_ends_with empty suffix")
        return 1
    } else {}
    if (not (str_ends_with "" "")) {
        (println "FAIL: str_ends_with both empty")
        return 1
    } else {}
    if (str_ends_with "abc" "xabc") {
        (println "FAIL: str_ends_with suffix longer than string")
        return 1
    } else {}
    (println "OK: test_str_ends_with passed")
    return 0
}

shadow test_str_ends_with {
    assert (== (test_str_ends_with) 0)
}

fn test_str_index_of() -> int {
    let idx1: int = (str_index_of "hello" "e")
    if (!= idx1 1) {
        (println "FAIL: str_index_of basic")
        return 1
    } else {}
    let idx2: int = (str_index_of "hello" "x")
    if (!= idx2 -1) {
        (println "FAIL: str_index_of not found")
        return 1
    } else {}
    let idx3: int = (str_index_of "List<Point>" "<")
    if (!= idx3 4) {
        (println "FAIL: str_index_of angle bracket")
        return 1
    } else {}
    let idx4: int = (str_index_of "hello world" "world")
    if (!= idx4 6) {
        (println "FAIL: str_index_of substring")
        return 1
    } else {}
    let idx5: int = (str_index_of "test" "")
    if (!= idx5 0) {
        (println "FAIL: str_index_of empty needle")
        return 1
    } else {}
    (println "OK: test_str_index_of passed")
    return 0
}

shadow test_str_index_of {
    assert (== (test_str_index_of) 0)
}

fn main() -> int {
    let r1: int = (test_str_starts_with)
    let r2: int = (test_str_ends_with)
    let r3: int = (test_str_index_of)
    return (+ (+ r1 r2) r3)
}
