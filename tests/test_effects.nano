/* test_effects.nano — Algebraic effect system tests */

/* ── Effect declarations ─────────────────────────────────────────────── */

effect Console {
    print : string -> void,
    read  : string -> string
}

effect Counter {
    tick  : int -> void,
    total : int -> int
}

/* ── Functions that perform effects ──────────────────────────────────── */

fn greet(name: string) -> void {
    perform Console.print(name)
}

fn count_up(n: int) -> void {
    let mut i = 0
    while (< i n) {
        perform Counter.tick(i)
        set i (+ i 1)
    }
}

fn emit_hello() -> void {
    perform Console.print("hello effects")
}

/* ── Tests ───────────────────────────────────────────────────────────── */

shadow greet {
    /* Handler intercepts Console.print and records the argument */
    let mut captured = ""
    handle (greet "world") with {
        Console.print(s) -> {
            set captured s
        }
    }
    assert (== captured "world")
}

shadow count_up {
    /* Handler intercepts Counter.tick and counts invocations */
    let mut ticks = 0
    handle (count_up 3) with {
        Counter.tick(v) -> {
            set ticks (+ ticks 1)
        }
    }
    assert (== ticks 3)
}

shadow emit_hello {
    /* Handler intercepts Console.print from emit_hello */
    let mut result = ""
    handle (emit_hello) with {
        Console.print(s) -> {
            set result s
        }
    }
    assert (== result "hello effects")
}

fn main() -> int {
    (println "Effect system: declarations parsed, handlers registered.")
    return 0
}

shadow main { assert true }
