# Tests for the graphx module.
#
# Covers:
#   graphx_graph_new  -- graph construction
#   graphx_add_edge   -- weighted edge addition
#   graphx_add_arc    -- unweighted arc addition
#   graphx_dijkstra   -- weighted shortest path (returns int: cost or -1)
#   graphx_topo_sort  -- topological ordering via Kahn's BFS (returns array<int>)
#   graphx_has_cycle  -- directed-cycle predicate
#
# Also demonstrates how callers can layer union + match on top of the
# integer-based module API to build expressive local result types.
#
# Run: ./bin/nano tests/test_graphx.nano
import "modules/std/graphx/graphx.nano" as graphx

# ---------------------------------------------------------------------------
# Local union types: callers build rich result types on top of the int API.
# ---------------------------------------------------------------------------
union PathResult {
    Reached     { dist: int },
    Unreachable {}
}

union TopoResult {
    Sorted        { order: array<int> },
    CycleDetected {}
}

# Wrap graphx_dijkstra to produce a PathResult union.
fn dijkstra_result(g: graphx.Graph, source: int, target: int) -> PathResult {
    let d: int = (graphx.graphx_dijkstra g source target)
    if (== d -1) {
        return PathResult.Unreachable {}
    } else {
        return PathResult.Reached { dist: d }
    }
}

# Wrap graphx_topo_sort to produce a TopoResult union.
fn topo_result(g: graphx.Graph) -> TopoResult {
    let ord: array<int> = (graphx.graphx_topo_sort g)
    let gn: int = g.n
    if (== (array_length ord) gn) {
        return TopoResult.Sorted { order: ord }
    } else {
        return TopoResult.CycleDetected {}
    }
}

# ---------------------------------------------------------------------------
# test_graph_construction: verify node and edge counts.
# ---------------------------------------------------------------------------
fn test_graph_construction() -> int {
    let g0: graphx.Graph = (graphx.graphx_graph_new 5)
    if (not (== g0.n 5)) {
        (println "FAIL: graph_new n")
        return 1
    } else {}
    if (not (== g0.m 0)) {
        (println "FAIL: graph_new m")
        return 1
    } else {}

    let g1: graphx.Graph = (graphx.graphx_add_edge g0 0 3 10)
    if (not (== g1.m 1)) {
        (println "FAIL: add_edge m")
        return 1
    } else {}
    if (not (== (at g1.edge_src 0) 0)) {
        (println "FAIL: add_edge src")
        return 1
    } else {}
    if (not (== (at g1.edge_dst 0) 3)) {
        (println "FAIL: add_edge dst")
        return 1
    } else {}
    if (not (== (at g1.edge_wt 0) 10)) {
        (println "FAIL: add_edge wt")
        return 1
    } else {}

    let g2: graphx.Graph = (graphx.graphx_add_arc g1 3 4)
    if (not (== g2.m 2)) {
        (println "FAIL: add_arc m")
        return 1
    } else {}
    if (not (== (at g2.edge_wt 1) 1)) {
        (println "FAIL: add_arc weight should be 1")
        return 1
    } else {}

    (println "OK: test_graph_construction")
    return 0
}

# ---------------------------------------------------------------------------
# test_dijkstra_basic: shortest paths on a small weighted directed graph.
#
# Graph (4 nodes):
#   0->1 (w=4), 0->2 (w=1), 2->1 (w=2), 1->3 (w=1), 2->3 (w=5)
#
# Expected distances from source 0:
#   d(0,0)=0, d(0,1)=3 (0->2->1), d(0,2)=1, d(0,3)=4 (0->2->1->3)
# ---------------------------------------------------------------------------
fn test_dijkstra_basic() -> int {
    let mut g: graphx.Graph = (graphx.graphx_graph_new 4)
    set g (graphx.graphx_add_edge g 0 1 4)
    set g (graphx.graphx_add_edge g 0 2 1)
    set g (graphx.graphx_add_edge g 2 1 2)
    set g (graphx.graphx_add_edge g 1 3 1)
    set g (graphx.graphx_add_edge g 2 3 5)

    if (not (== (graphx.graphx_dijkstra g 0 0) 0)) {
        (println "FAIL: dijkstra 0->0 should be 0")
        return 1
    } else {}
    if (not (== (graphx.graphx_dijkstra g 0 1) 3)) {
        (println "FAIL: dijkstra 0->1 should be 3")
        return 1
    } else {}
    if (not (== (graphx.graphx_dijkstra g 0 2) 1)) {
        (println "FAIL: dijkstra 0->2 should be 1")
        return 1
    } else {}
    if (not (== (graphx.graphx_dijkstra g 0 3) 4)) {
        (println "FAIL: dijkstra 0->3 should be 4")
        return 1
    } else {}

    (println "OK: test_dijkstra_basic")
    return 0
}

# ---------------------------------------------------------------------------
# test_dijkstra_with_union: demonstrate union + match on the dijkstra result.
# ---------------------------------------------------------------------------
fn test_dijkstra_with_union() -> int {
    let mut g: graphx.Graph = (graphx.graphx_graph_new 4)
    set g (graphx.graphx_add_edge g 0 1 4)
    set g (graphx.graphx_add_edge g 0 2 1)
    set g (graphx.graphx_add_edge g 2 1 2)
    set g (graphx.graphx_add_edge g 1 3 1)

    # Reached case
    let r1: PathResult = (dijkstra_result g 0 3)
    match r1 {
        Reached(v) => {
            if (not (== v.dist 4)) {
                (println "FAIL: PathResult.Reached dist should be 4")
                return 1
            } else {}
        }
        Unreachable(_) => {
            (println "FAIL: 0->3 should be reachable")
            return 1
        }
    }

    # Unreachable case: node 3 has no outgoing edges back to 0
    let r2: PathResult = (dijkstra_result g 3 0)
    match r2 {
        Reached(_) => {
            (println "FAIL: 3->0 should be unreachable")
            return 1
        }
        Unreachable(_) => {}
    }

    (println "OK: test_dijkstra_with_union")
    return 0
}

# ---------------------------------------------------------------------------
# test_dijkstra_unreachable: verify -1 is returned for disconnected pairs.
# ---------------------------------------------------------------------------
fn test_dijkstra_unreachable() -> int {
    # Directed graph: 0->1 only; node 2 is isolated.
    let mut g: graphx.Graph = (graphx.graphx_graph_new 3)
    set g (graphx.graphx_add_edge g 0 1 5)

    if (not (== (graphx.graphx_dijkstra g 0 2) -1)) {
        (println "FAIL: isolated node should return -1")
        return 1
    } else {}

    (println "OK: test_dijkstra_unreachable")
    return 0
}

# ---------------------------------------------------------------------------
# test_dijkstra_single_node: distance from source to itself is always 0.
# ---------------------------------------------------------------------------
fn test_dijkstra_single_node() -> int {
    let g: graphx.Graph = (graphx.graphx_graph_new 1)
    if (not (== (graphx.graphx_dijkstra g 0 0) 0)) {
        (println "FAIL: self-distance should be 0")
        return 1
    } else {}
    (println "OK: test_dijkstra_single_node")
    return 0
}

# ---------------------------------------------------------------------------
# test_topo_sort_dag: valid ordering on a known 6-node DAG.
#
# Edges: 5->2, 5->0, 4->0, 4->1, 2->3, 3->1
# Expected Kahn order: [4, 5, 2, 0, 3, 1]
# ---------------------------------------------------------------------------
fn test_topo_sort_dag() -> int {
    let mut g: graphx.Graph = (graphx.graphx_graph_new 6)
    set g (graphx.graphx_add_arc g 5 2)
    set g (graphx.graphx_add_arc g 5 0)
    set g (graphx.graphx_add_arc g 4 0)
    set g (graphx.graphx_add_arc g 4 1)
    set g (graphx.graphx_add_arc g 2 3)
    set g (graphx.graphx_add_arc g 3 1)

    let ord: array<int> = (graphx.graphx_topo_sort g)
    if (not (== (array_length ord) 6)) {
        (println "FAIL: topo order length should be 6")
        return 1
    } else {}
    if (not (== (at ord 0) 4)) {
        (println "FAIL: topo order[0] should be 4")
        return 1
    } else {}
    if (not (== (at ord 1) 5)) {
        (println "FAIL: topo order[1] should be 5")
        return 1
    } else {}
    if (not (== (at ord 5) 1)) {
        (println "FAIL: topo order[5] should be 1")
        return 1
    } else {}

    (println "OK: test_topo_sort_dag")
    return 0
}

# ---------------------------------------------------------------------------
# test_topo_sort_with_union: demonstrate union + match on the topo result.
# ---------------------------------------------------------------------------
fn test_topo_sort_with_union() -> int {
    # DAG: linear chain 0->1->2->3
    let mut g_dag: graphx.Graph = (graphx.graphx_graph_new 4)
    set g_dag (graphx.graphx_add_arc g_dag 0 1)
    set g_dag (graphx.graphx_add_arc g_dag 1 2)
    set g_dag (graphx.graphx_add_arc g_dag 2 3)

    let r_dag: TopoResult = (topo_result g_dag)
    match r_dag {
        Sorted(v) => {
            if (not (== (array_length v.order) 4)) {
                (println "FAIL: DAG topo order length should be 4")
                return 1
            } else {}
            if (not (== (at v.order 0) 0)) {
                (println "FAIL: chain topo order[0] should be 0")
                return 1
            } else {}
        }
        CycleDetected(_) => {
            (println "FAIL: linear chain should be a DAG")
            return 1
        }
    }

    # Cycle: 0->1->2->0
    let mut g_cyc: graphx.Graph = (graphx.graphx_graph_new 3)
    set g_cyc (graphx.graphx_add_arc g_cyc 0 1)
    set g_cyc (graphx.graphx_add_arc g_cyc 1 2)
    set g_cyc (graphx.graphx_add_arc g_cyc 2 0)

    let r_cyc: TopoResult = (topo_result g_cyc)
    match r_cyc {
        Sorted(_) => {
            (println "FAIL: cycle should return CycleDetected")
            return 1
        }
        CycleDetected(_) => {}
    }

    (println "OK: test_topo_sort_with_union")
    return 0
}

# ---------------------------------------------------------------------------
# test_topo_sort_cycle: topo_sort returns short array when cycle exists.
# ---------------------------------------------------------------------------
fn test_topo_sort_cycle() -> int {
    let mut g: graphx.Graph = (graphx.graphx_graph_new 3)
    set g (graphx.graphx_add_arc g 0 1)
    set g (graphx.graphx_add_arc g 1 2)
    set g (graphx.graphx_add_arc g 2 0)

    let ord: array<int> = (graphx.graphx_topo_sort g)
    if (not (< (array_length ord) 3)) {
        (println "FAIL: cyclic graph topo order should be shorter than 3")
        return 1
    } else {}

    (println "OK: test_topo_sort_cycle")
    return 0
}

# ---------------------------------------------------------------------------
# test_has_cycle: convenience predicate for cycle detection.
# ---------------------------------------------------------------------------
fn test_has_cycle() -> int {
    # Acyclic: simple chain 0->1->2
    let mut g_chain: graphx.Graph = (graphx.graphx_graph_new 3)
    set g_chain (graphx.graphx_add_arc g_chain 0 1)
    set g_chain (graphx.graphx_add_arc g_chain 1 2)
    if (graphx.graphx_has_cycle g_chain) {
        (println "FAIL: chain should be acyclic")
        return 1
    } else {}

    # Cyclic: 0->1->2->0
    let mut g_cycle: graphx.Graph = (graphx.graphx_graph_new 3)
    set g_cycle (graphx.graphx_add_arc g_cycle 0 1)
    set g_cycle (graphx.graphx_add_arc g_cycle 1 2)
    set g_cycle (graphx.graphx_add_arc g_cycle 2 0)
    if (not (graphx.graphx_has_cycle g_cycle)) {
        (println "FAIL: 0->1->2->0 should be cyclic")
        return 1
    } else {}

    # Self-loop: 0->0
    let mut g_self: graphx.Graph = (graphx.graphx_graph_new 2)
    set g_self (graphx.graphx_add_arc g_self 0 0)
    if (not (graphx.graphx_has_cycle g_self)) {
        (println "FAIL: self-loop should be cyclic")
        return 1
    } else {}

    # Empty graph (no edges): always acyclic
    let g_empty: graphx.Graph = (graphx.graphx_graph_new 4)
    if (graphx.graphx_has_cycle g_empty) {
        (println "FAIL: empty graph should be acyclic")
        return 1
    } else {}

    (println "OK: test_has_cycle")
    return 0
}

# ---------------------------------------------------------------------------
# main: run all tests; return non-zero on first failure.
# ---------------------------------------------------------------------------
fn main() -> int {
    if (not (== (test_graph_construction) 0)) { return 1 } else {}
    if (not (== (test_dijkstra_basic) 0)) { return 1 } else {}
    if (not (== (test_dijkstra_with_union) 0)) { return 1 } else {}
    if (not (== (test_dijkstra_unreachable) 0)) { return 1 } else {}
    if (not (== (test_dijkstra_single_node) 0)) { return 1 } else {}
    if (not (== (test_topo_sort_dag) 0)) { return 1 } else {}
    if (not (== (test_topo_sort_with_union) 0)) { return 1 } else {}
    if (not (== (test_topo_sort_cycle) 0)) { return 1 } else {}
    if (not (== (test_has_cycle) 0)) { return 1 } else {}
    (println "ALL OK: test_graphx")
    return 0
}
