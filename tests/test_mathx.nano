# Tests for the mathx module. Each helper gets a test fn; main runs them all and
# returns non-zero on the first failure. Run: ./bin/nano tests/test_mathx.nano
import "modules/std/mathx/mathx.nano" as mathx

fn test_abs() -> int {
    if (not (== (mathx.mathx_abs (- 0 5)) 5)) {
        (println "FAIL: mathx_abs negative")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 7) 7)) {
        (println "FAIL: mathx_abs positive")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 0) 0)) {
        (println "FAIL: mathx_abs zero")
        return 1
    } else {}
    (println "OK: test_abs")
    return 0
}

fn test_clamp() -> int {
    if (not (== (mathx.mathx_clamp 5 0 10) 5)) {
        (println "FAIL: mathx_clamp in-range")
        return 1
    } else {}
    if (not (== (mathx.mathx_clamp (- 0 3) 0 10) 0)) {
        (println "FAIL: mathx_clamp below")
        return 1
    } else {}
    if (not (== (mathx.mathx_clamp 99 0 10) 10)) {
        (println "FAIL: mathx_clamp above")
        return 1
    } else {}
    (println "OK: test_clamp")
    return 0
}

fn main() -> int {
    if (not (== (test_abs) 0)) {
        return 1
    } else {}
    if (not (== (test_clamp) 0)) {
        return 1
    } else {}
    (println "ALL OK: test_mathx")
    return 0
}
