# Tests for the mathx module. Each helper gets a test fn; main runs them all and
# returns non-zero on the first failure. Run: ./bin/nano tests/test_mathx.nano
import "modules/std/mathx/mathx.nano" as mathx

fn test_abs() -> int {
    if (not (== (mathx.mathx_abs (- 0 5)) 5)) {
        (println "FAIL: mathx_abs negative")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 7) 7)) {
        (println "FAIL: mathx_abs positive")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 0) 0)) {
        (println "FAIL: mathx_abs zero")
        return 1
    } else {}
    (println "OK: test_abs")
    return 0
}

fn test_gcd() -> int {
    if (not (== (mathx.mathx_gcd 12 8) 4)) {
        (println "FAIL: mathx_gcd 12 8")
        return 1
    } else {}
    if (not (== (mathx.mathx_gcd 17 5) 1)) {
        (println "FAIL: mathx_gcd 17 5")
        return 1
    } else {}
    if (not (== (mathx.mathx_gcd 0 5) 5)) {
        (println "FAIL: mathx_gcd 0 5")
        return 1
    } else {}
    if (not (== (mathx.mathx_gcd (- 0 12) 8) 4)) {
        (println "FAIL: mathx_gcd negative")
        return 1
    } else {}
    (println "OK: test_gcd")
    return 0
}

fn test_clamp() -> int {
    if (not (== (mathx.mathx_clamp 5 0 10) 5)) {
        (println "FAIL: mathx_clamp in-range")
        return 1
    } else {}
    if (not (== (mathx.mathx_clamp (- 0 3) 0 10) 0)) {
        (println "FAIL: mathx_clamp below")
        return 1
    } else {}
    if (not (== (mathx.mathx_clamp 42 0 10) 10)) {
        (println "FAIL: mathx_clamp above")
        return 1
    } else {}
    if (not (== (mathx.mathx_clamp 7 7 7) 7)) {
        (println "FAIL: mathx_clamp equal bounds")
        return 1
    } else {}
    (println "OK: test_clamp")
    return 0
}

fn test_isqrt() -> int {
    if (not (== (mathx.mathx_isqrt 0) 0)) {
        (println "FAIL: mathx_isqrt 0 should be 0")
        return 1
    } else {}
    if (not (== (mathx.mathx_isqrt 1) 1)) {
        (println "FAIL: mathx_isqrt 1 should be 1")
        return 1
    } else {}
    if (not (== (mathx.mathx_isqrt 15) 3)) {
        (println "FAIL: mathx_isqrt 15 should be 3")
        return 1
    } else {}
    if (not (== (mathx.mathx_isqrt 16) 4)) {
        (println "FAIL: mathx_isqrt 16 should be 4")
        return 1
    } else {}
    if (not (== (mathx.mathx_isqrt 24) 4)) {
        (println "FAIL: mathx_isqrt 24 should be 4")
        return 1
    } else {}
    if (not (== (mathx.mathx_isqrt 25) 5)) {
        (println "FAIL: mathx_isqrt 25 should be 5")
        return 1
    } else {}
    (println "OK: test_isqrt")
    return 0
}

fn test_is_prime() -> int {
    if (not (mathx.mathx_is_prime 2)) {
        (println "FAIL: mathx_is_prime 2 should be true")
        return 1
    } else {}
    if (not (mathx.mathx_is_prime 7)) {
        (println "FAIL: mathx_is_prime 7 should be true")
        return 1
    } else {}
    if (mathx.mathx_is_prime 9) {
        (println "FAIL: mathx_is_prime 9 should be false")
        return 1
    } else {}
    if (mathx.mathx_is_prime 1) {
        (println "FAIL: mathx_is_prime 1 should be false")
        return 1
    } else {}
    if (mathx.mathx_is_prime 25) {
        (println "FAIL: mathx_is_prime 25 should be false")
        return 1
    } else {}
    if (not (mathx.mathx_is_prime 97)) {
        (println "FAIL: mathx_is_prime 97 should be true")
        return 1
    } else {}
    (println "OK: test_is_prime")
    return 0
}

fn main() -> int {
    if (not (== (test_abs) 0)) {
        return 1
    } else {}
    if (not (== (test_gcd) 0)) {
        return 1
    } else {}
    if (not (== (test_clamp) 0)) {
        return 1
    } else {}
    if (not (== (test_isqrt) 0)) {
        return 1
    } else {}
    if (not (== (test_is_prime) 0)) {
        return 1
    } else {}
    (println "ALL OK: test_mathx")
    return 0
}
