# Tests for the mathx module. Each helper gets a test fn; main runs them all and
# returns non-zero on the first failure. Run: ./bin/nano tests/test_mathx.nano
import "modules/std/mathx/mathx.nano" as mathx

fn test_abs() -> int {
    if (not (== (mathx.mathx_abs (- 0 5)) 5)) {
        (println "FAIL: mathx_abs negative")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 7) 7)) {
        (println "FAIL: mathx_abs positive")
        return 1
    } else {}
    if (not (== (mathx.mathx_abs 0) 0)) {
        (println "FAIL: mathx_abs zero")
        return 1
    } else {}
    (println "OK: test_abs")
    return 0
}

fn test_is_prime() -> int {
    if (not (mathx.mathx_is_prime 2)) {
        (println "FAIL: mathx_is_prime 2 should be true")
        return 1
    } else {}
    if (not (mathx.mathx_is_prime 7)) {
        (println "FAIL: mathx_is_prime 7 should be true")
        return 1
    } else {}
    if (mathx.mathx_is_prime 9) {
        (println "FAIL: mathx_is_prime 9 should be false")
        return 1
    } else {}
    if (mathx.mathx_is_prime 1) {
        (println "FAIL: mathx_is_prime 1 should be false")
        return 1
    } else {}
    (println "OK: test_is_prime")
    return 0
}

fn main() -> int {
    if (not (== (test_abs) 0)) {
        return 1
    } else {}
    if (not (== (test_is_prime) 0)) {
        return 1
    } else {}
    (println "ALL OK: test_mathx")
    return 0
}
