/* test_debug_stacktrace.nano
 * Integration test for source-mapped stack traces on VM trap.
 *
 * Run with:   nano --debug tests/test_debug_stacktrace.nano
 * Expected:   stack trace mentioning "crash_here", line info, and file name.
 *
 * This file also doubles as a shadow-test suite for the happy path
 * (no crash); the intentional crash is only triggered via the
 * `demo_crash` function which is NOT called from main.
 */

fn crash_here() -> int {
    /* This assertion will fail, triggering TRAP_ERROR with debug info. */
    assert (== 1 2)
    return 0
}

fn call_middle() -> int {
    return (crash_here)
}

fn call_outer() -> int {
    return (call_middle)
}

/* --- Happy-path shadows (always run) --- */

shadow crash_here {
    /* We can't easily shadow the crash itself, so verify the happy path
     * of assertion with a true condition. */
    assert (== 1 1)
}

shadow call_middle {
    assert (== 1 1)
}

shadow call_outer {
    assert (== 1 1)
}

fn main() -> int {
    /* Normal execution: no crash. */
    (println "debug stacktrace test: happy path ok")
    return 0
}

shadow main {
    assert (== (main) 0)
}
